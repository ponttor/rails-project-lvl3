
<div class="mt-5 mb-5 pb-5">
  <div class="container">
    <div class="p-4 border shadow bg-white rounded-3">
              <h2 class="mb-4"><%= t('index.title') %><h2>
              <hr>

      <div class="row d-flex justify-content-between">
          <% @bulletins.each do |bulletin| %>
            <div class="col-3 pt-2">
    <div class="card shadow-sm">
    <% if bulletin.image.representable? %>
      <%= image_tag(bulletin.image, class: 'card-img-top x-object-fit-cover') %>
    <% end %>
      <div class="card-body">
        <a href="/bulletins/51">
          <h5 class="card-title">
            <%= link_to bulletin.title, bulletin, class: "h5 link-dark text-decoration-none" %>
          </h5>
        </a>
        <h6 class="card-subtitle mb-2 text-muted"><%= distance_of_time_in_words_to_now(bulletin.created_at) %></h6>
      </div>
    </div>
  </div>
          <% end %>
      </div>
  </div>
</div>